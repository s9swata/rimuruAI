{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WordsOfWorld",
  "version": "0.1.0",
  "identifier": "com.wordsofworld.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "WordsOfWorld - Voice to Text",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 300,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.groq.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Voice to text transcription tool",
    "longDescription": "WordsOfWorld is a voice-to-text transcription tool that helps you convert speech to text using global shortcuts.",
    "category": "Productivity",
    "macOS": {
      "entitlements": "./entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
