{
  "productName": "Raphael",
  "version": "0.1.0",
  "identifier": "ai.rimuru.raphael",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Raphael",
        "width": 420,
        "height": 680,
        "minWidth": 360,
        "minHeight": 500,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
